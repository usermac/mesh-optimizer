# -------------------------------------------------------------------------
# SECURITY NOTE:
# This file (.env.example) is safe to commit to Git.
# The real .env file contains secrets and MUST NOT be committed.
#
# INSTRUCTIONS:
# 1. On your local machine (for dev), copy this to .env and fill in real values.
# 2. On your PRODUCTION SERVER, create a .env file with the real production keys.
# -------------------------------------------------------------------------

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# -------------------------------------------------------------------------
# DEPLOYMENT COMMAND (Run on the SERVER):
# -------------------------------------------------------------------------
# Yes, you run this on the server.
#
# When running the container, add the `--env-file .env` flag so the app
# can safely load these secrets.
#
# Example command:
# docker run -d \
#   --env-file .env \
#   -p 80:80 -p 443:443 \
#   -v $(pwd)/uploads:/app/uploads \
#   -v $(pwd)/server:/app/server \
#   --restart always \
#   --name api \
#   mesh-api
# -------------------------------------------------------------------------
